{
  "name": "reader-electron",
  "version": "0.1.0",
  "description": "Cross-platform reader with TTS and licensing",
  "author": "Your Name <you@example.com>",
  "private": true,
  "main": "electron-main/main.js",
  "scripts": {
    "dev": "vite",
    "start": "concurrently \"npm:serve-electron\" \"npm:dev\"",
    "serve-electron": "wait-on http://localhost:5173 && electron .",
    "dev-all": "concurrently \"npm:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:electron": "electron .",
    "build": "vite build && set GH_TOKEN= && electron-builder --publish never",
    "build:renderer": "vite build",
    "build:win": "vite build && electron-builder --windows nsis --publish never",
    "package-artifacts": "powershell -File scripts/package-artifacts.ps1",
    "generate-icons": "node scripts/generate-icons.js",
    "check-ci": "node scripts/check-ci.js",
    "test": "echo \"no tests yet\""
  },
  "dependencies": {
    "electron-store": "^8.0.0",
    "epubjs": "^0.3.88",
    "pdfjs-dist": "^2.14.305",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tesseract.js": "^4.0.2",
    "electron-publisher-never": "file:build/electron-publisher-never.js",
    "axios": "^1.4.0",
    "tar": "^6.1.11"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "vite": "^5.0.0",
    "concurrently": "^8.0.0",
    "wait-on": "^7.0.0",
    "electron-builder": "^24.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "sharp": "^0.32.0",
    "png-to-ico": "^1.0.0",
    "@octokit/rest": "^19.0.0"
  },
  "build": {
    "appId": "com.example.reader",
    "publish": null,
    "icon": "build/icons/icon-256.png",
    "files": [
      "electron-main/**/*",
      "renderer/dist/**/*",
      "native-helpers/**/*",
      "license-server/**/*"
    ],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": ["AppImage", "deb"], "category": "Utility" }
  }
}
